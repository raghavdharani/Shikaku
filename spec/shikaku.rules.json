{
  "specVersion": "1.0.0",
  "game": {
    "name": "Shikaku",
    "platforms": ["ios", "android"]
  },
  "board": {
    "allowedSizes": [
      { "width": 6, "height": 6 },
      { "width": 8, "height": 8 },
      { "width": 10, "height": 10 }
    ],
    "minWidth": 6,
    "minHeight": 6
  },
  "rules": {
    "singleCluePerRectangle": true,
    "rectangleAreaEqualsClue": true,
    "fullCoverageRequired": true,
    "overlapAllowed": false,
    "requireUniqueSolution": true
  },
  "difficultyTiers": [
    {
      "name": "easy",
      "boardSizes": ["6x6"],
      "notes": "Lower ambiguity and simpler factor combinations"
    },
    {
      "name": "medium",
      "boardSizes": ["8x8"],
      "notes": "Moderate branching complexity"
    },
    {
      "name": "hard",
      "boardSizes": ["10x10"],
      "notes": "Higher ambiguity and deeper solver search"
    }
  ]
}

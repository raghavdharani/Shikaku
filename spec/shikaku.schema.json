{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Shikaku Rules Spec",
  "type": "object",
  "required": [
    "specVersion",
    "game",
    "board",
    "rules",
    "difficultyTiers"
  ],
  "properties": {
    "specVersion": { "type": "string" },
    "game": {
      "type": "object",
      "required": ["name", "platforms"],
      "properties": {
        "name": { "type": "string" },
        "platforms": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "board": {
      "type": "object",
      "required": ["allowedSizes", "minWidth", "minHeight"],
      "properties": {
        "allowedSizes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["width", "height"],
            "properties": {
              "width": { "type": "integer", "minimum": 1 },
              "height": { "type": "integer", "minimum": 1 }
            },
            "additionalProperties": false
          },
          "minItems": 1
        },
        "minWidth": { "type": "integer", "minimum": 1 },
        "minHeight": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "object",
      "required": [
        "singleCluePerRectangle",
        "rectangleAreaEqualsClue",
        "fullCoverageRequired",
        "overlapAllowed",
        "requireUniqueSolution"
      ],
      "properties": {
        "singleCluePerRectangle": { "type": "boolean" },
        "rectangleAreaEqualsClue": { "type": "boolean" },
        "fullCoverageRequired": { "type": "boolean" },
        "overlapAllowed": { "type": "boolean" },
        "requireUniqueSolution": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "difficultyTiers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "boardSizes"],
        "properties": {
          "name": { "type": "string" },
          "boardSizes": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
